# frozen_string_literal: true

require "json"
require "deliver/upload_metadata"

default_platform(:ios)

APP_IDENTIFIER = "com.danfakkeldy.routey"
TEAM_ID = "8AXNA5B37R"
FASTLANE_DIR = __dir__
ROOT_PATH = File.expand_path("..", FASTLANE_DIR)
PROJECT_PATH = File.join(ROOT_PATH, "app/Routey/Routey.xcodeproj")
SCHEME = "Routey"
METADATA_PATH = File.join(FASTLANE_DIR, "metadata")
TESTFLIGHT_METADATA_PATH = File.join(FASTLANE_DIR, "testflight")
SCREENSHOTS_PATH = File.join(FASTLANE_DIR, "screenshots")
DEFAULT_API_KEY_JSON_PATH = File.join(FASTLANE_DIR, "api_key.json")
DEFAULT_EXPORT_METHOD = "app-store"

module RouteyDeliverFirstVersionPatch
  def review_attachment_file(version)
    super
  rescue RuntimeError => error
    raise unless error.message == "No data" && options[:app_review_attachment_file].nil?

    UI.important("No App Review detail exists yet; skipping review attachment cleanup.")
  end
end

Deliver::UploadMetadata.prepend(RouteyDeliverFirstVersionPatch)

def env_value(name)
  value = ENV[name]
  return nil if value.nil? || value.strip.empty?

  value
end

def app_store_connect_key
  json_key_content = env_value("APP_STORE_CONNECT_API_KEY_JSON")
  json_key_path = env_value("APP_STORE_CONNECT_API_KEY_JSON_PATH") || env_value("APP_STORE_CONNECT_API_KEY_JSON_FILEPATH")
  json_key_path = File.expand_path(json_key_path, ROOT_PATH) if json_key_path
  json_key_path ||= DEFAULT_API_KEY_JSON_PATH if File.exist?(DEFAULT_API_KEY_JSON_PATH)

  if json_key_content || json_key_path
    key_data = JSON.parse(json_key_content || File.read(json_key_path))
    missing_keys = %w[key_id issuer_id key].reject { |key| key_data[key].to_s.length.positive? }
    UI.user_error!("App Store Connect API key JSON is missing: #{missing_keys.join(', ')}") unless missing_keys.empty?

    return app_store_connect_api_key(
      key_id: key_data["key_id"],
      issuer_id: key_data["issuer_id"],
      key_content: key_data["key"],
      is_key_content_base64: false,
      duration: (key_data["duration"] || env_value("APP_STORE_CONNECT_API_KEY_DURATION") || "1200").to_i,
      in_house: key_data.fetch("in_house", false)
    )
  end

  key_id = env_value("APP_STORE_CONNECT_API_KEY_ID")
  issuer_id = env_value("APP_STORE_CONNECT_API_ISSUER_ID")
  key_filepath = env_value("APP_STORE_CONNECT_API_KEY_FILEPATH") || env_value("APP_STORE_CONNECT_API_KEY_PATH")
  key_content = env_value("APP_STORE_CONNECT_API_KEY_CONTENT")
  key_filepath = File.expand_path(key_filepath, ROOT_PATH) if key_filepath

  unless key_id && (key_filepath || key_content)
    UI.user_error!(
      "Add fastlane/api_key.json, set APP_STORE_CONNECT_API_KEY_JSON_PATH, or set " \
      "APP_STORE_CONNECT_API_KEY_ID plus APP_STORE_CONNECT_API_KEY_FILEPATH/CONTENT. " \
      "See fastlane/.env.example."
    )
  end

  options = {
    key_id: key_id,
    issuer_id: issuer_id,
    duration: (env_value("APP_STORE_CONNECT_API_KEY_DURATION") || "1200").to_i,
    in_house: false
  }

  if key_content
    options[:key_content] = key_content
    options[:is_key_content_base64] = env_value("APP_STORE_CONNECT_API_KEY_IS_KEY_CONTENT_BASE64") == "true"
  else
    options[:key_filepath] = key_filepath
  end

  app_store_connect_api_key(options)
end

def metadata_file(locale, filename)
  File.join(METADATA_PATH, locale, filename)
end

def testflight_metadata_file(locale, filename)
  File.join(TESTFLIGHT_METADATA_PATH, locale, filename)
end

def metadata_locale
  env_value("FASTLANE_METADATA_LOCALE") || "en-US"
end

def text_file(path)
  return nil unless File.exist?(path)

  text = File.read(path).strip
  text.empty? ? nil : text
end

def metadata_text(locale, filename)
  text_file(metadata_file(locale, filename))
end

def testflight_metadata_text(locale, filename)
  text_file(testflight_metadata_file(locale, filename))
end

def testflight_whats_new(locale)
  testflight_metadata_text(locale, "whats_new.txt") || metadata_text(locale, "release_notes.txt")
end

def testflight_description(locale)
  testflight_metadata_text(locale, "description.txt") || metadata_text(locale, "description.txt")
end

def testflight_marketing_url(locale)
  env_value("TESTFLIGHT_MARKETING_URL") ||
    testflight_metadata_text(locale, "marketing_url.txt") ||
    metadata_text(locale, "marketing_url.txt")
end

def testflight_privacy_policy_url(locale)
  env_value("TESTFLIGHT_PRIVACY_POLICY_URL") ||
    testflight_metadata_text(locale, "privacy_policy_url.txt") ||
    metadata_text(locale, "privacy_policy_url.txt") ||
    metadata_text(locale, "privacy_url.txt")
end

def testflight_feedback_email
  env_value("TESTFLIGHT_FEEDBACK_EMAIL") || env_value("PILOT_BETA_APP_FEEDBACK")
end

def testflight_metadata_options(locale)
  whats_new = testflight_whats_new(locale)
  UI.user_error!(
    "Missing TestFlight What to Test text. Add #{testflight_metadata_file(locale, 'whats_new.txt')} " \
    "or #{metadata_file(locale, 'release_notes.txt')}."
  ) if whats_new.nil?
  UI.user_error!("TestFlight What to Test text is #{whats_new.bytesize}/4000 bytes") if whats_new.bytesize > 4000

  description = testflight_description(locale)
  UI.user_error!("TestFlight beta description is #{description.bytesize}/4000 bytes") if description && description.bytesize > 4000

  localized_app_info = {}
  localized_app_info[:description] = description if description

  feedback_email = testflight_feedback_email
  localized_app_info[:feedback_email] = feedback_email if feedback_email

  marketing_url = testflight_marketing_url(locale)
  localized_app_info[:marketing_url] = marketing_url if marketing_url

  privacy_policy_url = testflight_privacy_policy_url(locale)
  localized_app_info[:privacy_policy_url] = privacy_policy_url if privacy_policy_url

  options = {
    changelog: whats_new,
    localized_build_info: {
      locale => {
        whats_new: whats_new
      }
    }
  }

  options[:localized_app_info] = { locale => localized_app_info } unless localized_app_info.empty?
  options
end

platform :ios do
  desc "Validate App Store metadata text files locally"
  lane :validate_metadata do
    locale = metadata_locale
    locale_path = File.join(METADATA_PATH, locale)
    UI.user_error!("Missing metadata locale directory: #{locale_path}") unless Dir.exist?(locale_path)

    limits = {
      "name.txt" => 30,
      "subtitle.txt" => 30,
      "promotional_text.txt" => 170,
      "keywords.txt" => 100,
      "description.txt" => 4000,
      "release_notes.txt" => 4000
    }

    limits.each do |filename, limit|
      path = metadata_file(locale, filename)
      UI.user_error!("Missing metadata file: #{path}") unless File.exist?(path)

      length = File.read(path).strip.length
      UI.user_error!("#{path} is #{length}/#{limit} characters") if length > limit
      UI.message("#{filename}: #{length}/#{limit}")
    end

    keywords = File.read(metadata_file(locale, "keywords.txt")).strip
    UI.user_error!("keywords.txt must be comma-separated") unless keywords.include?(",")
    UI.user_error!("keywords.txt must not contain spaces after commas") if keywords.include?(", ")

    UI.success("Metadata files are ready for deliver.")
  end

  desc "Validate TestFlight metadata text files locally"
  lane :validate_testflight_metadata do
    locale = metadata_locale
    options = testflight_metadata_options(locale)
    whats_new = options.fetch(:changelog)
    description = options.dig(:localized_app_info, locale, :description)

    UI.message("TestFlight locale: #{locale}")
    UI.message("whats_new.txt: #{whats_new.bytesize}/4000 bytes")
    UI.message("description: #{description.bytesize}/4000 bytes") if description
    UI.message("feedback email: #{testflight_feedback_email ? 'configured' : 'not configured'}")
    UI.success("TestFlight metadata is ready for pilot.")
  end

  desc "Upload App Store metadata from fastlane/metadata"
  lane :metadata do
    validate_metadata
    api_key = app_store_connect_key

    deliver(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      metadata_path: METADATA_PATH,
      screenshots_path: SCREENSHOTS_PATH,
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true
    )
  end

  desc "Update TestFlight metadata for an already-uploaded Routey build"
  lane :testflight_metadata do |options|
    validate_testflight_metadata
    api_key = app_store_connect_key
    locale = metadata_locale

    testflight_options = {
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      app_platform: "ios",
      distribute_only: true,
      skip_submission: true,
      skip_waiting_for_build_processing: true
    }.merge(testflight_metadata_options(locale))

    testflight_options[:app_version] = options[:app_version].to_s if options[:app_version]
    testflight_options[:build_number] = options[:build_number].to_s if options[:build_number]

    upload_to_testflight(testflight_options)
  end

  desc "Build an App Store archive for Routey"
  lane :build do |options|
    xcargs = ["-skipMacroValidation -skipPackagePluginValidation"]
    xcargs << "CURRENT_PROJECT_VERSION=#{options[:build_number]}" if options[:build_number]

    build_app(
      project: PROJECT_PATH,
      scheme: SCHEME,
      export_method: DEFAULT_EXPORT_METHOD,
      xcargs: xcargs.join(" "),
      clean: true
    )
  end

  desc "Build and upload Routey to TestFlight"
  lane :beta do |options|
    setup_ci if is_ci

    channel = (options[:channel] || env_value("RELEASE_CHANNEL") || "").to_s.downcase
    testflight_group, external_distribution = case channel
                                              when "nightly" then ["Nightly", false]
                                              else [nil, false]
                                              end
    UI.message(
      "Release train channel: #{channel.empty? ? '(none)' : channel} -> " \
      "TestFlight group: #{testflight_group || '(none)'}, " \
      "external: #{external_distribution}"
    )

    api_key = app_store_connect_key

    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    ) + 1
    UI.message("Build number for this run: #{next_build}")

    sync_code_signing(
      api_key: api_key,
      type: "appstore",
      app_identifier: [APP_IDENTIFIER],
      readonly: is_ci
    )

    if is_ci
      mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
      profile = mapping[APP_IDENTIFIER]
      UI.user_error!("match did not return an app-store profile for #{APP_IDENTIFIER}") if profile.nil?

      update_code_signing_settings(
        path: PROJECT_PATH,
        use_automatic_signing: false,
        targets: [SCHEME],
        team_id: TEAM_ID,
        code_sign_identity: "Apple Distribution",
        profile_name: profile
      )
    end

    build(build_number: next_build)

    testflight_options = {
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: false,
      distribute_external: external_distribution,
      notify_external_testers: external_distribution
    }.merge(testflight_metadata_options(metadata_locale))

    # Internal testers automatically see processed internal builds. Routey avoids
    # passing the Nightly group because Pilot treats explicit group distribution
    # as an external submission that requires Beta App Review metadata.
    if testflight_group && external_distribution
      testflight_options[:groups] = [testflight_group]
      testflight_options[:distribute_external] = true
    end

    upload_to_testflight(testflight_options)
  end
end
