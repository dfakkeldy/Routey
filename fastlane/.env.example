# Copy this file to fastlane/.env if you need local overrides.
# fastlane/.env, fastlane/api_key.json, and *.p8 key files are ignored by git.

FASTLANE_TEAM_ID=8AXNA5B37R
FASTLANE_ITC_TEAM_ID=
FASTLANE_APPLE_ID=

APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_JSON_PATH=fastlane/api_key.json
APP_STORE_CONNECT_API_KEY_FILEPATH=fastlane/AuthKey_YOUR_KEY_ID.p8
APP_STORE_CONNECT_API_KEY_DURATION=1200

# Alternative for CI: set the key text directly instead of committing a file.
APP_STORE_CONNECT_API_KEY_CONTENT=
APP_STORE_CONNECT_API_KEY_IS_KEY_CONTENT_BASE64=false

# Used by fastlane match to decrypt the private signing repo.
MATCH_PASSWORD=

# Defaults to en-US when omitted.
FASTLANE_METADATA_LOCALE=en-US

# Optional TestFlight beta app metadata. Leave blank locally unless you want
# Fastlane to create/update the beta app feedback email and URLs.
TESTFLIGHT_FEEDBACK_EMAIL=
TESTFLIGHT_MARKETING_URL=
TESTFLIGHT_PRIVACY_POLICY_URL=
